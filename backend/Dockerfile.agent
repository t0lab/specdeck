# SpecDeck agent (LangGraph) image. Build context = ./backend.
# Skeleton runs `langgraph dev` (in-memory checkpointer). Production swaps to a
# `langgraph build` image backed by the Postgres checkpointer.
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim

WORKDIR /app
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

COPY . .
RUN uv sync --frozen --package specdeck-agent

WORKDIR /app/agent
EXPOSE 2024
CMD ["uv", "run", "langgraph", "dev", "--host", "0.0.0.0", "--port", "2024", "--no-browser"]
