# SpecDeck — environment template. Copy to .env and fill secrets.
# RULE: secrets/API-keys live ONLY in backend (gateway/agent). NEVER in the
# Next.js client — only NEXT_PUBLIC_* values reach the browser.

# ── Frontend (browser-exposed) ──
# Local dev (no docker). Under docker-compose this is set from GATEWAY_PUBLIC_URL.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# ── Public URLs via Cloudflare tunnel (read by docker-compose) ──
# Set to the tunnel hostnames when exposing through t0lab_network.
GATEWAY_PUBLIC_URL=http://localhost:8000
WEB_PUBLIC_URL=http://localhost:3000

# ── Gateway (FastAPI) ──
AGENT_URL=http://localhost:2024
DATABASE_URL=postgresql://specdeck:specdeck@localhost:5432/specdeck
REDIS_URL=redis://localhost:6379/0

# ── Workspace provisioning + GitHub auth (gateway, backend-only) ──
# Managed root where git repos are cloned/init'd (Docker named volume in compose).
WORKSPACE_ROOT=/workspaces
# GitHub uses OAuth Device Flow (like `gh login`): NO client secret, NO callback.
# A client_id is not a secret; SpecDeck ships a default. Set this only to use your
# own OAuth App (must have "Enable Device Flow" ticked).
GITHUB_CLIENT_ID=
# Fernet key for encrypting the GitHub token at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Agent (LangGraph Server) — secrets backend-only ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Postgres checkpointer (production). `langgraph dev` uses in-memory.
LANGGRAPH_POSTGRES_URI=postgresql://specdeck:specdeck@localhost:5432/specdeck

# ── Postgres container ──
POSTGRES_USER=specdeck
POSTGRES_PASSWORD=specdeck
POSTGRES_DB=specdeck
