# SpecDeck web — example environment.
# Copy to `.env` (gitignored) for local dev. Contains NO secrets.
#
# Only NEXT_PUBLIC_* vars are exposed to the browser. Backend secrets/API keys
# belong to the Gateway / Agent Server, never here.

# Forward-looking: base URL of the FastAPI Gateway. Optional — the mock app
# runs entirely on static data and boots fine with this unset.
# NEXT_PUBLIC_GATEWAY_URL=https://specdeck.timezlab.org/api
